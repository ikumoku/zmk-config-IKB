/* =========================================================
 * Date: 2026-04-09 22:13
 * Filename: config/boards/shields/Test/IKB_R.overlay
 * @details
 * 右手側（IKB_R）のハードウェア・デバイスツリー定義ファイルです。
 * 名前の衝突を避けるため、互換性ラベルを pixart,pmw3610-alt に変更しています。
 * 新しいドライバー仕様に基づき、CPI(解像度)やX/Yの反転設定を
 * .conf ファイルからこちらのデバイスツリーノードに移動しました。
 * スクロール等のレイヤー設定はZMK標準のリスナー制御に移行したため無効化しています。
 * ========================================================= */

#include "IKB.dtsi"

&default_transform {
    col-offset = <6>;
};

&kscan0 {
    col-gpios
        = <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
        , <&gpio0 10 GPIO_ACTIVE_HIGH>
        ;
};

/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };                              
    };
};

&xiao_serial { status = "disabled"; };

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        /* 名前衝突回避のため -alt を付与 */
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        
        /* 旧 .conf から .overlay へ移動してきた機能 */
        cpi = <400>;
        invert-x;
        invert-y;

        /*
         * 【重要】新仕様では以下の機能はドライバーから削除され、
         * ZMK本体の機能（keymapの zmk,input-listener）で制御するようになりました。
         * ビルドエラーを防ぐため、コメントアウト（無効化）して残しています。
         * automouse-layer = <4>;
         * scroll-layers = <5>;
         */
    };
};

&usbd {
    status = "okay";
};
