/* =========================================================
 * Date: 2026-04-09 22:50
 * Filename: config/boards/shields/Test/IKB_R.overlay
 * @details
 * 右手側（IKB_R）のハードウェア・デバイスツリー定義ファイルです。
 * 上下が逆になる問題（Y軸の反転）を、ドライバー側の invert-y プロパティを
 * 削除することで修正しました。また、最新のZMK入力システム（Input Processor）
 * を利用して、オートマウスレイヤー（AML）の自動切り替え機能を復元しました。
 * トラックボール操作時にレイヤー1へ自動移行し、700ms後に元のレイヤーへ戻ります。
 * ========================================================= */

#include "IKB.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
/* ZMKの入力プロセッサ（AML等）を使用するための定義 */
#include <input/processors.dtsi>

&default_transform {
    col-offset = <6>;
};

&kscan0 {
    col-gpios
        = <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 8 GPIO_ACTIVE_HIGH> 
        , <&xiao_d 7 GPIO_ACTIVE_HIGH> 
        , <&gpio0 10 GPIO_ACTIVE_HIGH>
        ;
};

/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        
        /* * オートマウスレイヤー（AML）の復元
         * ボールを動かすと「レイヤー1」に切り替わり「700ms」維持します。
         * もし以前のレイヤーが4だった場合は <&zip_temp_layer 4 700> に変更してください。
         */
        input-processors = <&zip_temp_layer 1 700>;
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };                              
    };
};

&xiao_serial { status = "disabled"; };

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        
        cpi = <400>;

        /* * Y軸（上下）の反転を修正しました。
         * X軸（左右）も逆の場合は、ここにある invert-x; を消してください。
         */
        invert-x;

        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};

&usbd {
    status = "okay";
};
