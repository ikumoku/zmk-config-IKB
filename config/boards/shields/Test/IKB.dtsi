/* =========================================================
 * Date: 2026-04-12 18:30
 * Filename: config/boards/shields/Test/IKB.dtsi
 * @details
 * info.jsonから抽出した精密な座標データを physical_layout に適用しました。
 * これにより ZMK Studio 上で実機と全く同じエルゴノミクス配置が表示されます。
 * 合わせて、Zephyr 4.1.0で非推奨となった kscan の label プロパティを削除し
 * ビルド時の警告（deprecated warning）が出ないように修正しました。
 * ========================================================= */

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,physical-layout = &ikb_physical_layout;
    };
    
    ikb_physical_layout: ikb_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "IKB Custom Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        /* * フォーマット: <&key_physical_attrs 幅 高さ X座標 Y座標 回転角 Rx Ry>
         * 単位: 100 = 1U
         */
        keys
            /* === 1段目 === */
            = <&key_physical_attrs 100 100    0   62    0  0  0>  // RC(0,0)
            , <&key_physical_attrs 100 100  100   25    0  0  0>  // RC(0,1)
            , <&key_physical_attrs 100 100  201    0    0  0  0>  // RC(0,2)
            , <&key_physical_attrs 100 100  301   13    0  0  0>  // RC(0,3)
            , <&key_physical_attrs 100 100  401   26    0  0  0>  // RC(0,4)

            , <&key_physical_attrs 100 100  850   26    0  0  0>  // RC(0,6)
            , <&key_physical_attrs 100 100  951   13    0  0  0>  // RC(0,7)
            , <&key_physical_attrs 100 100 1051    0    0  0  0>  // RC(0,8)
            , <&key_physical_attrs 100 100 1151   25    0  0  0>  // RC(0,9)
            , <&key_physical_attrs 100 100 1251   62    0  0  0>  // RC(0,10)

            /* === 2段目 === */
            , <&key_physical_attrs 100 100    0  162    0  0  0>  // RC(1,0)
            , <&key_physical_attrs 100 100  100  125    0  0  0>  // RC(1,1)
            , <&key_physical_attrs 100 100  201  100    0  0  0>  // RC(1,2)
            , <&key_physical_attrs 100 100  301  113    0  0  0>  // RC(1,3)
            , <&key_physical_attrs 100 100  401  127    0  0  0>  // RC(1,4)

            , <&key_physical_attrs 100 100  850  127    0  0  0>  // RC(1,6)
            , <&key_physical_attrs 100 100  951  114    0  0  0>  // RC(1,7)
            , <&key_physical_attrs 100 100 1051  100    0  0  0>  // RC(1,8)
            , <&key_physical_attrs 100 100 1151  125    0  0  0>  // RC(1,9)
            , <&key_physical_attrs 100 100 1251  162    0  0  0>  // RC(1,10)

            /* === 3段目 === */
            , <&key_physical_attrs 100 100    0  262    0  0  0>  // RC(2,0)
            , <&key_physical_attrs 100 100  100  225    0  0  0>  // RC(2,1)
            , <&key_physical_attrs 100 100  201  201    0  0  0>  // RC(2,2)
            , <&key_physical_attrs 100 100  301  214    0  0  0>  // RC(2,3)
            , <&key_physical_attrs 100 100  401  227    0  0  0>  // RC(2,4)
            , <&key_physical_attrs 100 100  501  227    0  0  0>  // RC(2,5)

            , <&key_physical_attrs 100 100  750  227    0  0  0>  // RC(3,6)
            , <&key_physical_attrs 100 100  850  227    0  0  0>  // RC(2,6)
            , <&key_physical_attrs 100 100  951  214    0  0  0>  // RC(2,7)
            , <&key_physical_attrs 100 100 1051  201    0  0  0>  // RC(2,8)
            , <&key_physical_attrs 100 100 1151  225    0  0  0>  // RC(2,9)
            , <&key_physical_attrs 100 100 1251  262    0  0  0>  // RC(2,10)

            /* === 4段目 === */
            , <&key_physical_attrs 100 100    0  362    0  0  0>  // RC(3,0)
            , <&key_physical_attrs 100 100  100  326    0  0  0>  // RC(3,1)
            , <&key_physical_attrs 100 100  200  301    0  0  0>  // RC(3,2)

            , <&key_physical_attrs 100 100  322  353    0  0  0>  // RC(3,3)
            , <&key_physical_attrs 100 100  422  353    0  0  0>  // RC(3,4)
            , <&key_physical_attrs 100 100  522  353    0  0  0>  // RC(3,5)

            , <&key_physical_attrs 100 100  716  353    0  0  0>  // RC(3,7)
            , <&key_physical_attrs 100 100  816  353    0  0  0>  // RC(3,8)
            
            , <&key_physical_attrs 100 100 1151  326    0  0  0>  // RC(3,9)
            , <&key_physical_attrs 100 100 1251  363    0  0  0>  // RC(3,10)
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <4>;               
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)                     RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)                     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(3,6) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)     RC(3,7) RC(3,8)                 RC(3,9) RC(3,10)         
        >;
    };
    
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        /* label = "KSCAN"; は非推奨のため削除しました */
        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> 			
            ;
    };

/*
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <12>;
        status = "disabled";
    };

    right_encoder: encoder_right {
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <10>;
    };
*/

};
